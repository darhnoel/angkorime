#!/usr/bin/env bash
set -e

if command -v ibus >/dev/null 2>&1; then
  ibus write-cache || true
fi

cat <<'MSG'
KhmerIME was installed.

To enable it:
  1. Restart IBus or log out and back in.
  2. Open Settings -> Keyboard -> Input Sources.
  3. Search for Khmer and add KhmerIME.

If needed, run: ibus restart
MSG
